# ─────────────────────────────────────────────────────────────────────────
# Frontend configuration (Vite).
# Copy to `.env` and adjust. All variables MUST be prefixed with VITE_ so
# Vite embeds them into the built bundle at compile time.
# ─────────────────────────────────────────────────────────────────────────

# Base URL for API calls.
# In production (Docker): nginx proxies /api → api:8000, so "/" is correct.
# For local `vite dev` outside Docker: point at the running API directly.
VITE_API_BASE_URL=/api

# Maximum file size shown in the upload hint (informational only — the
# real limit is enforced by the API via MAX_UPLOAD_BYTES).
VITE_MAX_UPLOAD_MB=2048

# Polling interval for job status (milliseconds).
VITE_POLL_INTERVAL_MS=1500

# Optional: set to the same value as backend API_AUTH_TOKEN.
# VITE_API_AUTH_TOKEN=change-me
