# ─────────────────────────────────────────────────────────────────────────
# MediaScribe configuration. Copy to `.env` and adjust.
# Every value here is read by app/config.py — nothing is hard-coded elsewhere.
# ─────────────────────────────────────────────────────────────────────────

# --- Service ---
APP_NAME=MediaScribe
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=true

# --- HTTP / CORS ---
API_HOST=0.0.0.0
API_PORT=8000
# Optional: require clients to send X-API-Key with this value.
# API_AUTH_TOKEN=change-me
# JSON array; "*" allows all origins (dev only).
CORS_ALLOW_ORIGINS=["*"]
# Number of Uvicorn worker processes (set in docker-compose / entrypoint).
WEB_CONCURRENCY=2

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=mediascribe

# --- RabbitMQ / Celery ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_TASK_QUEUE=transcription
CELERY_CONCURRENCY=2
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE_SECONDS=2
STUCK_JOB_TIMEOUT_SECONDS=600
STUCK_JOB_REAPER_INTERVAL_SECONDS=60

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/uploads

# --- Upload limits ---
MAX_UPLOAD_BYTES=2147483648          # 2 GiB
UPLOAD_CHUNK_BYTES=1048576           # 1 MiB streaming reads

# --- Transcription model (Hugging Face) ---
TRANSCRIBER=whisper                  # whisper | fake (tests)
WHISPER_MODEL=openai/whisper-small
WHISPER_DEVICE=cpu                   # cpu | cuda
# WHISPER_LANGUAGE=he                # omit for auto-detect

# --- Audio chunking ---
CHUNK_THRESHOLD_SECONDS=60           # below this: single-task fast path
CHUNK_LENGTH_SECONDS=30
CHUNK_OVERLAP_SECONDS=1
AUDIO_SAMPLE_RATE=16000

# --- Observability ---
METRICS_ENABLED=true
